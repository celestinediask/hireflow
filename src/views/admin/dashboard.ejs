<%- include('../layout-wide') %>
    <style>
      .profile-btn {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: #4a6cf7;
        color: #fff;
        font-size: 16px;
        font-weight: 700;
        border: none;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: background 0.2s;
        text-decoration: none;
      }
      .profile-btn:hover { background: #3b5de7; }
    </style>

    <div class="flex-between mb-20">
      <h1>Admin Dashboard</h1>
      <a href="/admin/profile" class="profile-btn" title="My Profile">
        <%= user.username[0].toUpperCase() %>
      </a>
    </div>

    <h2>HR Users</h2>
    <div class="mb-20">
      <a href="/admin/hr/new" class="btn btn-small">+ Add HR User</a>
    </div>
    <% if (hrUsers.length === 0) { %>
      <p class="text-muted mb-20">No HR users yet. Create one to get started.</p>
    <% } else { %>
      <table class="mb-20">
        <thead>
          <tr>
            <th>Username</th>
            <th>Email</th>
            <th>Password</th>
            <th>Created</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% hrUsers.forEach(u => { %>
            <tr>
              <td><%= u.username %></td>
              <td><%= u.email %></td>
              <td style="font-family:monospace"><%= u.plain_password || '—' %></td>
              <td><%= u.created_at %></td>
              <td style="white-space:nowrap">
                <a href="/admin/hr/<%= u.id %>/edit" title="Edit" style="display:inline-flex;align-items:center;justify-content:center;width:32px;height:32px;border-radius:6px;background:#2a3a5a;color:#7ab0e3;border:1px solid #2a4a6a;text-decoration:none;transition:background 0.2s" onmouseover="this.style.background='#3a4a6a'" onmouseout="this.style.background='#2a3a5a'">
                  <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                </a>
                &nbsp;
                <form method="POST" action="/admin/hr/<%= u.id %>/delete" style="display:inline" onsubmit="return confirm('Delete this HR user?')">
                  <button type="submit" title="Delete" style="display:inline-flex;align-items:center;justify-content:center;width:32px;height:32px;border-radius:6px;background:#3d1a1a;color:#e74c3c;border:1px solid #5a2a2a;cursor:pointer;transition:background 0.2s" onmouseover="this.style.background='#5a1a1a'" onmouseout="this.style.background='#3d1a1a'">
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                  </button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>
</body>
</html>
