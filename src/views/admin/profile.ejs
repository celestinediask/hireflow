<%- include('../layout-wide') %>
    <div class="flex-between mb-20">
      <h1>My Profile</h1>
      <a href="/admin" class="btn btn-small btn-secondary">&larr; Back to Dashboard</a>
    </div>

    <% if (error) { %><div class="error"><%= error %></div><% } %>
    <% if (success) { %><div class="success"><%= success %></div><% } %>

    <form method="POST" action="/admin/profile" style="max-width:400px">
      <div class="form-group">
        <label>Username</label>
        <input type="text" name="username" value="<%= user.username %>" required>
      </div>
      <div class="form-group">
        <label>Email</label>
        <input type="email" name="email" value="<%= user.email %>" required>
      </div>
      <div class="form-group">
        <label>Current Password</label>
        <% if (plainPassword) { %>
          <div style="display:flex;gap:8px;align-items:center">
            <input type="password" id="currentPwd" value="<%= plainPassword %>" readonly style="flex:1;font-family:monospace;cursor:default">
            <button type="button" onclick="togglePwd()" title="Show/hide password" style="background:none;border:1px solid #2a2a4a;border-radius:6px;padding:7px 10px;cursor:pointer;color:#b0b0b0;line-height:0;flex-shrink:0">
              <svg id="eyeIcon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                <circle cx="12" cy="12" r="3"></circle>
              </svg>
              <svg id="eyeOffIcon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none">
                <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path>
                <line x1="1" y1="1" x2="23" y2="23"></line>
              </svg>
            </button>
          </div>
        <% } else { %>
          <div class="text-muted">Log out and log back in to view your password.</div>
        <% } %>
      </div>
      <div class="form-group">
        <label>New Password <span style="color:#555;font-size:12px">(leave blank to keep current)</span></label>
        <input type="password" name="password" autocomplete="new-password">
      </div>
      <button type="submit" class="btn">Save Changes</button>
    </form>

    <div style="margin-top:32px;padding-top:24px;border-top:1px solid #2a2a4a">
      <form method="POST" action="/admin/logout">
        <button type="submit" class="btn btn-danger">Logout</button>
      </form>
    </div>

  <% if (plainPassword) { %>
  <script>
    function togglePwd() {
      const input = document.getElementById('currentPwd');
      const eye = document.getElementById('eyeIcon');
      const eyeOff = document.getElementById('eyeOffIcon');
      if (input.type === 'password') {
        input.type = 'text';
        eye.style.display = 'none';
        eyeOff.style.display = '';
      } else {
        input.type = 'password';
        eye.style.display = '';
        eyeOff.style.display = 'none';
      }
    }
  </script>
  <% } %>
  </div>
</body>
</html>
