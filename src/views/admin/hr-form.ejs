<%- include('../layout-wide') %>
    <h1><%= hrUser ? 'Edit HR User' : 'Create HR User' %></h1>

    <% if (error) { %>
      <div class="error"><%= error %></div>
    <% } %>

    <form method="POST" action="<%= hrUser ? '/admin/hr/' + hrUser.id : '/admin/hr' %>">
      <div class="form-group">
        <label for="username">Username</label>
        <input type="text" id="username" name="username" value="<%= hrUser ? hrUser.username : '' %>" required>
      </div>
      <div class="form-group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" value="<%= hrUser ? hrUser.email : '' %>" required>
      </div>
      <% if (hrUser) { %>
      <div class="form-group">
        <label>Current Password</label>
        <% if (hrUser.plain_password) { %>
          <div style="background:#0f3460;border:1px solid #2a2a4a;border-radius:6px;padding:10px 12px;font-size:15px;color:#e0e0e0;font-family:monospace"><%= hrUser.plain_password %></div>
        <% } else { %>
          <form method="POST" action="/admin/hr/<%= hrUser.id %>/reveal" style="display:flex;gap:8px;align-items:center">
            <input type="password" name="password" placeholder="Enter current password" style="padding:6px 10px;font-size:13px;width:200px">
            <button type="submit" class="btn btn-small">Reveal</button>
          </form>
        <% } %>
      </div>
      <% } %>
      <div class="form-group">
        <label for="password">New Password<%= hrUser ? ' (leave blank to keep current)' : '' %></label>
        <input type="password" id="password" name="password" <%= hrUser ? '' : 'required' %>>
      </div>
      <button type="submit" class="btn"><%= hrUser ? 'Update' : 'Create' %> HR User</button>
    </form>

    <div class="mt-20">
      <a href="/admin">&larr; Back to dashboard</a>
    </div>
  </div>
</body>
</html>
