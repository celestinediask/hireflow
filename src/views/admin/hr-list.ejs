<%- include('../layout-wide') %>
    <div class="flex-between mb-20">
      <h1>HR Users</h1>
      <a href="/admin/hr/new" class="btn btn-small">+ Add HR User</a>
    </div>

    <% if (hrUsers.length === 0) { %>
      <p class="text-muted">No HR users yet.</p>
    <% } else { %>
      <table>
        <thead>
          <tr>
            <th>Username</th>
            <th>Email</th>
            <th>Password</th>
            <th>Created</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% hrUsers.forEach(u => { %>
            <tr>
              <td><%= u.username %></td>
              <td><%= u.email %></td>
              <td><%= u.plain_password || '—' %></td>
              <td><%= u.created_at %></td>
              <td>
                <a href="/admin/hr/<%= u.id %>/edit" class="btn btn-small btn-secondary">Edit</a>
                <form method="POST" action="/admin/hr/<%= u.id %>/delete" style="display:inline" onsubmit="return confirm('Delete this HR user?')">
                  <button type="submit" class="btn btn-danger btn-small">Delete</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>

    <div class="mt-20">
      <a href="/admin">&larr; Back to dashboard</a>
    </div>
  </div>
</body>
</html>
