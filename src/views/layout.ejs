<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Auth App</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #0d0d14;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .card {
      background: #16161f;
      border: 1px solid #232330;
      border-radius: 12px;
      box-shadow: 0 8px 32px rgba(0,0,0,0.5);
      padding: 40px;
      width: 100%;
      max-width: 420px;
    }
    .card h1 {
      margin-bottom: 28px;
      color: #f0f0f5;
      font-size: 22px;
      text-align: center;
      font-weight: 600;
      letter-spacing: -0.3px;
    }
    .form-group { margin-bottom: 16px; }
    .form-group label {
      display: block;
      margin-bottom: 6px;
      font-weight: 500;
      color: #aaaaC0;
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .form-group input {
      width: 100%;
      padding: 10px 14px;
      border: 1px solid #2a2a3d;
      border-radius: 8px;
      font-size: 15px;
      background: #1e1e2d;
      color: #f0f0f5;
      transition: border-color 0.2s, box-shadow 0.2s;
    }
    .form-group input:focus {
      outline: none;
      border-color: #7c6af7;
      box-shadow: 0 0 0 3px rgba(124,106,247,0.15);
    }
    .btn {
      width: 100%;
      padding: 12px;
      background: #7c6af7;
      color: #fff;
      border: none;
      border-radius: 8px;
      font-size: 15px;
      font-weight: 600;
      cursor: pointer;
      margin-top: 8px;
      transition: background 0.2s, transform 0.1s;
      letter-spacing: 0.2px;
    }
    .btn:hover { background: #6a58e8; }
    .btn:active { transform: scale(0.99); }
    .btn-danger { background: #ef4444; }
    .btn-danger:hover { background: #dc2626; }
    .error {
      background: rgba(239,68,68,0.1);
      border: 1px solid rgba(239,68,68,0.25);
      color: #f87171;
      padding: 10px 14px;
      border-radius: 8px;
      margin-bottom: 16px;
      font-size: 14px;
    }
    .success {
      background: rgba(16,185,129,0.1);
      border: 1px solid rgba(16,185,129,0.25);
      color: #34d399;
      padding: 10px 14px;
      border-radius: 8px;
      margin-bottom: 16px;
      font-size: 14px;
    }
    .link {
      text-align: center;
      margin-top: 18px;
      font-size: 14px;
      color: #9898b8;
    }
    .link a { color: #7c6af7; text-decoration: none; }
    .link a:hover { color: #a08af9; }
    .profile-info { margin-bottom: 20px; }
    .profile-info p {
      padding: 10px 0;
      border-bottom: 1px solid #232330;
      color: #c0c0d8;
      font-size: 15px;
    }
    .profile-info p span { font-weight: 600; color: #f0f0f5; }
    .message-text {
      text-align: center;
      color: #c0c0d8;
      line-height: 1.6;
      margin-bottom: 20px;
    }
  </style>
</head>
<body>
  <div class="card">

